{
  "name": "vscode-ash",
  "displayName": "Ash Agent Shell",
  "description": "Syntax highlighting, run, and check commands for Ash (.ash) agent shell scripts",
  "version": "0.1.0",
  "publisher": "Ash-Lang-kenny",
  "license": "AGPL-3.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:ash"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ash",
        "aliases": [
          "Ash",
          "ash"
        ],
        "extensions": [
          ".ash"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/ash-light.svg",
          "dark": "./icons/ash-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "ash",
        "scopeName": "source.ash",
        "path": "./syntaxes/ash.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "ash.runScript",
        "title": "Ash: Run Script"
      },
      {
        "command": "ash.checkScript",
        "title": "Ash: Check Script"
      },
      {
        "command": "ash.stopScript",
        "title": "Ash: Stop Script"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "ash.runScript",
          "when": "resourceLangId == ash",
          "group": "ash"
        },
        {
          "command": "ash.checkScript",
          "when": "resourceLangId == ash",
          "group": "ash"
        },
        {
          "command": "ash.stopScript",
          "when": "resourceLangId == ash",
          "group": "ash"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.0.0"
  }
}
