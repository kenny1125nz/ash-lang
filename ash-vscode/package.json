{
  "name": "ash-language",
  "displayName": "Ash Language Support",
  "description": "Syntax highlighting and language support for Ash (.ash) agent shell scripts",
  "version": "0.1.0",
  "publisher": "ash",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "contributes": {
    "languages": [
      {
        "id": "ash",
        "aliases": [
          "Ash",
          "ash"
        ],
        "extensions": [
          ".ash"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/ash-light.png",
          "dark": "./icons/ash-dark.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "ash",
        "scopeName": "source.ash",
        "path": "./syntaxes/ash.tmLanguage.json"
      }
    ]
  }
}
