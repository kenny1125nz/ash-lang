use std::sync::{Arc, Mutex};

// Test that our types are Send + Sync at compile time
fn assert_send<T: Send>() {}
fn assert_sync<T: Sync>() {}

// Replicate the type structure minimally to check
fn main() {
    // Token
    assert_send::<std::string::String>();
    assert_sync::<std::string::String>();
    assert_send::<usize>();
    assert_sync::<usize>();
    
    // f64 (used in Value)
    assert_send::<f64>();
    assert_sync::<f64>();
    
    // i64
    assert_send::<i64>();
    assert_sync::<i64>();
    
    // bool
    assert_send::<bool>();
    assert_sync::<bool>();
    
    // Vec<T> - Send+Sync if T: Send+Sync
    // Box<T> - Send+Sync if T: Send+Sync
    // Option<T> - Send+Sync if T: Send+Sync
    
    // HashMap<String, V> - Send+Sync if V: Send+Sync (keys are String which is Send+Sync)
    
    // Arc<Mutex<T>> - always Send+Sync (Mutex<T>: Send if T: Send, Sync if T: Send)
    // Arc<T>: Send+Sync if T: Send+Sync
    assert_send::<Arc<Mutex<String>>>();
    assert_sync::<Arc<Mutex<String>>>();
    
    // Box<dyn Write + Send>
    assert_send::<Box<dyn std::io::Write + Send>>();
    // Note: Box<dyn Write + Send> is NOT Sync because Write is not Sync
    // But wrapped in Mutex: Mutex<Box<dyn Write + Send>> IS Sync because Box<dyn Write + Send>: Send
    assert_send::<Mutex<Box<dyn std::io::Write + Send>>>();
    assert_sync::<Mutex<Box<dyn std::io::Write + Send>>>();
    
    println!("All types are Send + Sync!");
}
TESTEOF
