<div id="blog-highlight" style="display:none">
  <h2 class="text-2xl md:text-3xl font-bold mb-8">Latest from the Blog</h2>
  <div id="blog-highlight-posts" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"></div>
</div>

<script>
  (function() {
    fetch('/api/recent-posts')
      .then(function(r) { return r.json(); })
      .then(function(posts) {
        if (!Array.isArray(posts) || posts.length === 0) return;
        var container = document.getElementById('blog-highlight');
        var postsEl = document.getElementById('blog-highlight-posts');
        if (!container || !postsEl) return;
        posts.forEach(function(p) {
          var article = document.createElement('article');
          article.className = 'bg-bg-secondary border border-border rounded-lg p-5';
          var a = document.createElement('a');
          a.href = '/blog/' + p.slug;
          a.className = 'text-accent-green hover:underline font-semibold text-lg block mb-2';
          a.textContent = p.title;
          article.appendChild(a);
          if (p.date) {
            var dateEl = document.createElement('time');
            dateEl.className = 'text-text-secondary text-sm';
            dateEl.textContent = p.date;
            article.appendChild(dateEl);
          }
          postsEl.appendChild(article);
        });
        container.style.display = 'block';
      })
      .catch(function() {
        /* fail silently */
      });
  })();
</script>
