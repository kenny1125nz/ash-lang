---
export interface Props {
  title: string;
  body: string;
}

const { title, body } = Astro.props;
---

<div class="bg-bg-secondary border border-border rounded-lg p-6 flex flex-col">
  <h3 class="text-xl font-bold mb-3">{title}</h3>
  <p class="text-text-secondary mb-4 flex-1 text-sm leading-relaxed">{body}</p>
  <a href="/vision" class="text-accent-green hover:underline font-medium text-sm">Read our full mission →</a>
</div>
