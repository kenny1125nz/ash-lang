---
export interface NavChild {
  label: string;
  href: string;
}

export interface NavItem {
  label: string;
  href: string | null;
  children: NavChild[] | null;
}

const navItems: NavItem[] = [
  { label: 'Home', href: '/', children: null },
  { label: 'About', href: null, children: [
    { label: 'Vision & Mission', href: '/vision' },
    { label: 'Board of Directors', href: '/board' },
  ]},
  { label: 'Docs', href: null, children: [
    { label: 'Getting Started', href: '/docs' },
    { label: 'Agents', href: '/agents' },
    { label: 'Reference', href: '/reference' },
  ]},
  { label: 'Blog', href: '/blog', children: null },
  { label: 'Playground', href: '/playground', children: null },
  { label: 'Contact', href: '/contact', children: null },
];

const pathname = Astro.url.pathname;

function isActive(href: string | null): boolean {
  if (!href) return false;
  return pathname === href;
}

function isParentActive(item: NavItem): boolean {
  if (item.href && isActive(item.href)) return true;
  if (item.children) return item.children.some(c => isActive(c.href));
  return false;
}
---

<header class="border-b border-border bg-bg-secondary">
  <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="text-accent-green font-bold text-xl tracking-tight">ash</a>

      <nav class="hidden md:flex items-center gap-1">
        {navItems.map((item) => (
          item.children ? (
            <div class="relative group">
              <span class="flex items-center gap-1 px-3 py-2 rounded-lg text-sm font-medium cursor-default transition-colors {isParentActive(item) ? 'text-accent-green' : 'text-text-secondary hover:text-text-primary hover:bg-bg-tertiary'}">
                {item.label}
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </span>
              <div class="absolute left-0 top-full mt-1 w-52 bg-bg-secondary border border-border rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 py-1">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class="block px-4 py-2 text-sm {isActive(child.href) ? 'text-accent-green' : 'text-text-secondary hover:text-text-primary hover:bg-bg-tertiary'}"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={item.href!}
              class="px-3 py-2 rounded-lg text-sm font-medium transition-colors {isActive(item.href) ? 'text-accent-green' : 'text-text-secondary hover:text-text-primary hover:bg-bg-tertiary'}"
            >
              {item.label}
            </a>
          )
        ))}
        <a
          href="https://github.com/kenny1125nz/ash-lang"
          target="_blank"
          rel="noopener noreferrer"
          class="px-3 py-2 rounded-lg text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-bg-tertiary transition-colors inline-flex items-center gap-1.5"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12 24 5.37 18.63 0 12 0z"/></svg>
          GitHub
        </a>
      </nav>

      <button id="menu-toggle" class="md:hidden min-w-[44px] min-h-[44px] flex items-center justify-center text-text-primary hover:text-text-secondary transition-colors" aria-label="Toggle navigation menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="md:hidden hidden border-t border-border">
    <nav class="px-4 py-4 space-y-1">
      {navItems.map((item) => (
        item.children ? (
          <div class="space-y-1">
            <span class="block px-3 py-2 text-sm font-medium text-text-secondary cursor-default">{item.label}</span>
            <div class="ml-4 space-y-1">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class="block px-3 py-2 min-h-[44px] flex items-center rounded-lg text-sm font-medium transition-colors {isActive(child.href) ? 'text-accent-green' : 'text-text-secondary hover:text-text-primary hover:bg-bg-tertiary'}"
                >
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={item.href!}
            class="block px-3 py-2 min-h-[44px] flex items-center rounded-lg text-sm font-medium transition-colors {isActive(item.href) ? 'text-accent-green' : 'text-text-secondary hover:text-text-primary hover:bg-bg-tertiary'}"
          >
            {item.label}
          </a>
        )
      ))}
      <a
        href="https://github.com/kenny1125nz/ash-lang"
        target="_blank"
        rel="noopener noreferrer"
        class="block px-3 py-2 min-h-[44px] flex items-center rounded-lg text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-bg-tertiary transition-colors"
      >
        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12 24 5.37 18.63 0 12 0z"/></svg>
        GitHub
      </a>
    </nav>
  </div>
</header>

<script>
  document.getElementById('menu-toggle')?.addEventListener('click', () => {
    const menu = document.getElementById('mobile-menu');
    if (menu) {
      menu.classList.toggle('hidden');
    }
  });
</script>
