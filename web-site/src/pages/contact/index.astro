---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FeedbackForm from '../../components/FeedbackForm.astro';
---

<BaseLayout title="Contact">
  <div class="py-16 md:py-24 max-w-4xl mx-auto">
    <h1 class="text-3xl md:text-4xl font-bold mb-4">Contact</h1>
    <p class="text-text-secondary text-lg leading-relaxed mb-6">
      Have questions about Ash, found a bug, or want to share feedback? We'd love to hear from you.
    </p>
    <div class="flex flex-wrap gap-4 mb-12">
      <a href="https://github.com/anomalyco/ash" class="text-accent-green hover:underline font-medium text-sm">GitHub</a>
    </div>
    <h2 class="text-2xl font-bold mb-6">Send Us Feedback</h2>
    <FeedbackForm />
  </div>
</BaseLayout>
